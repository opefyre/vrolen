# Vrolen environment variables — TEMPLATE
# Copy this file to .env.local and fill in real values. .env.local is gitignored.
# Only `VITE_*` variables are exposed to the browser bundle.

# === Supabase ===
# Project URL from supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Publishable (browser-safe) API key — starts with sb_publishable_
# NEVER paste a sb_secret_ key here; secret keys are server-only.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-key>

# === Sentry ===
# Optional during local dev. Required in production.
# Find the DSN at sentry.io → your project → Settings → Client Keys (DSN)
VITE_SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
